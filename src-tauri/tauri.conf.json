{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Carrier",
  "version": "0.1.0",
  "identifier": "io.github.kristofferr.carrier",
  "build": {
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "app", "nsis", "deb", "appimage"],
    "publisher": "kristofferR",
    "category": "SocialNetworking",
    "shortDescription": "Distraction-free Messenger desktop client",
    "longDescription": "Carrier wraps the Facebook Messenger web app in a tiny native window and strips away the surrounding Facebook chrome — no Feed, no Reels, no Marketplace. Built with Tauri.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15"
    }
  }
}
