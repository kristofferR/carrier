<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!-- Merged into the generated app bundle's Info.plist by Tauri at build time. -->
<plist version="1.0">
<dict>
  <key>NSCameraUsageDescription</key>
  <string>Carrier needs camera access for Messenger video calls.</string>
  <key>NSMicrophoneUsageDescription</key>
  <string>Carrier needs microphone access for Messenger voice and video calls.</string>
  <!-- Saving Messenger media lands in ~/Downloads, which macOS protects via TCC
       (Files and Folders) even for non-sandboxed apps. This purpose string is the
       message shown in the permission prompt macOS raises on the first save. -->
  <key>NSDownloadsFolderUsageDescription</key>
  <string>Carrier saves photos, videos, and files you download from Messenger to your Downloads folder.</string>
  <key>NSAppTransportSecurity</key>
  <dict>
    <key>NSAllowsArbitraryLoads</key>
    <true/>
  </dict>
</dict>
</plist>
